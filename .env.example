NAS_ENVIRONMENT=development
NAS_LOG_LEVEL=INFO
NAS_API_HOST=0.0.0.0
NAS_API_PORT=8000

# Keep research data outside the Git repository. Quote paths containing spaces.
NAS_DATA_ROOT="/Volumes/AGNDJ 6TB/NaS-Core-Data"

NAS_DATABASE_URL=postgresql+psycopg://nas_core:nas_core@localhost:5432/nas_core

NAS_OBJECT_STORE_BACKEND=filesystem
NAS_OBJECT_STORE_BUCKET=nas-core-local
NAS_OBJECT_STORE_REGION=us-east-1
NAS_OBJECT_STORE_ENDPOINT_URL=http://localhost:9000
NAS_OBJECT_STORE_ACCESS_KEY=minioadmin
NAS_OBJECT_STORE_SECRET_KEY=minioadmin
NAS_OBJECT_STORE_SECURE=false

# AI screening is advisory only. Keep the key local; never commit it.
NAS_AI_PROVIDER=openai
NAS_AI_SCREENING_MODEL=gpt-5.6-sol
NAS_AI_SCREENING_REASONING_EFFORT=medium
OPENAI_API_KEY=
