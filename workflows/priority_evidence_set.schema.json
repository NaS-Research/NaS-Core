{
  "$defs": {
    "CandidateReviewState": {
      "enum": [
        "pending_screening",
        "pending_reappraisal",
        "eligible",
        "excluded",
        "access_restricted",
        "duplicate"
      ],
      "title": "CandidateReviewState",
      "type": "string"
    },
    "EvidenceDomain": {
      "enum": [
        "fixed_single_sample_classifier",
        "reference_and_centering",
        "gene_mapping_and_transformation",
        "margin_and_uncertainty",
        "technical_measurement_error",
        "perturbation_and_repeatability",
        "abstention_and_unclassifiable",
        "external_transport",
        "implementation_and_licensing"
      ],
      "title": "EvidenceDomain",
      "type": "string"
    },
    "PriorityCandidate": {
      "additionalProperties": false,
      "properties": {
        "candidate_id": {
          "pattern": "^(?:PMID|PMC|DOI):.+$",
          "title": "Candidate Id",
          "type": "string"
        },
        "doi": {
          "anyOf": [
            {
              "minLength": 1,
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Doi"
        },
        "evidence_domains": {
          "items": {
            "$ref": "#/$defs/EvidenceDomain"
          },
          "minItems": 1,
          "title": "Evidence Domains",
          "type": "array"
        },
        "founder_decision_recorded": {
          "title": "Founder Decision Recorded",
          "type": "boolean"
        },
        "pmcid": {
          "anyOf": [
            {
              "pattern": "^PMC[0-9]+$",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Pmcid"
        },
        "pmid": {
          "anyOf": [
            {
              "pattern": "^[0-9]+$",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Pmid"
        },
        "prior_artifact": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Prior Artifact"
        },
        "priority_rationale": {
          "minLength": 1,
          "title": "Priority Rationale",
          "type": "string"
        },
        "publication_year": {
          "maximum": 2100,
          "minimum": 1990,
          "title": "Publication Year",
          "type": "integer"
        },
        "review_state": {
          "$ref": "#/$defs/CandidateReviewState"
        },
        "title": {
          "minLength": 1,
          "title": "Title",
          "type": "string"
        }
      },
      "required": [
        "candidate_id",
        "title",
        "publication_year",
        "evidence_domains",
        "review_state",
        "priority_rationale",
        "founder_decision_recorded"
      ],
      "title": "PriorityCandidate",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "properties": {
    "autonomous_screening_decisions_allowed": {
      "title": "Autonomous Screening Decisions Allowed",
      "type": "boolean"
    },
    "candidates": {
      "items": {
        "$ref": "#/$defs/PriorityCandidate"
      },
      "maxItems": 30,
      "minItems": 1,
      "title": "Candidates",
      "type": "array"
    },
    "maximum_final_evidence_count": {
      "maximum": 30,
      "minimum": 1,
      "title": "Maximum Final Evidence Count",
      "type": "integer"
    },
    "question_id": {
      "pattern": "^NAS-RQ-[A-Z0-9]+$",
      "title": "Question Id",
      "type": "string"
    },
    "question_version": {
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$",
      "title": "Question Version",
      "type": "string"
    },
    "schema_version": {
      "default": "1.0.0",
      "title": "Schema Version",
      "type": "string"
    },
    "scientific_conclusions_drawn": {
      "title": "Scientific Conclusions Drawn",
      "type": "boolean"
    },
    "selection_rule": {
      "minLength": 1,
      "title": "Selection Rule",
      "type": "string"
    },
    "set_version": {
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$",
      "title": "Set Version",
      "type": "string"
    },
    "study_id": {
      "pattern": "^NAS-[A-Z0-9]+-[0-9]{3}$",
      "title": "Study Id",
      "type": "string"
    }
  },
  "required": [
    "set_version",
    "study_id",
    "question_id",
    "question_version",
    "maximum_final_evidence_count",
    "selection_rule",
    "candidates",
    "autonomous_screening_decisions_allowed",
    "scientific_conclusions_drawn"
  ],
  "title": "PriorityEvidenceSet",
  "type": "object"
}
