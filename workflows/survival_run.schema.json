{
  "$defs": {
    "AnalysisArtifact": {
      "additionalProperties": false,
      "properties": {
        "media_type": {
          "minLength": 1,
          "title": "Media Type",
          "type": "string"
        },
        "object_key": {
          "minLength": 1,
          "title": "Object Key",
          "type": "string"
        },
        "sha256": {
          "pattern": "^[a-f0-9]{64}$",
          "title": "Sha256",
          "type": "string"
        },
        "size_bytes": {
          "minimum": 0,
          "title": "Size Bytes",
          "type": "integer"
        }
      },
      "required": [
        "object_key",
        "media_type",
        "size_bytes",
        "sha256"
      ],
      "title": "AnalysisArtifact",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "properties": {
    "algorithm_version": {
      "title": "Algorithm Version",
      "type": "string"
    },
    "artifacts": {
      "items": {
        "$ref": "#/$defs/AnalysisArtifact"
      },
      "minItems": 1,
      "title": "Artifacts",
      "type": "array"
    },
    "code_revision": {
      "minLength": 7,
      "title": "Code Revision",
      "type": "string"
    },
    "cohort_build_id": {
      "pattern": "^[a-f0-9]{64}$",
      "title": "Cohort Build Id",
      "type": "string"
    },
    "cohort_manifest_sha256": {
      "pattern": "^[a-f0-9]{64}$",
      "title": "Cohort Manifest Sha256",
      "type": "string"
    },
    "environment": {
      "additionalProperties": {
        "type": "string"
      },
      "title": "Environment",
      "type": "object"
    },
    "executed_at": {
      "format": "date-time",
      "title": "Executed At",
      "type": "string"
    },
    "manifest_sha256": {
      "anyOf": [
        {
          "pattern": "^[a-f0-9]{64}$",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Manifest Sha256"
    },
    "parameters": {
      "additionalProperties": true,
      "title": "Parameters",
      "type": "object"
    },
    "protocol_tag": {
      "title": "Protocol Tag",
      "type": "string"
    },
    "protocol_version": {
      "title": "Protocol Version",
      "type": "string"
    },
    "random_seed": {
      "title": "Random Seed",
      "type": "integer"
    },
    "run_id": {
      "pattern": "^[a-f0-9]{64}$",
      "title": "Run Id",
      "type": "string"
    },
    "schema_version": {
      "default": "1.0.0",
      "title": "Schema Version",
      "type": "string"
    },
    "study_id": {
      "title": "Study Id",
      "type": "string"
    }
  },
  "required": [
    "run_id",
    "study_id",
    "protocol_version",
    "protocol_tag",
    "cohort_build_id",
    "cohort_manifest_sha256",
    "algorithm_version",
    "code_revision",
    "executed_at",
    "random_seed",
    "parameters",
    "environment",
    "artifacts"
  ],
  "title": "SurvivalRunManifest",
  "type": "object"
}
