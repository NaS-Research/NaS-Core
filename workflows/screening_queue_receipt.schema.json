{
  "$defs": {
    "ScreeningQueueSummary": {
      "additionalProperties": false,
      "properties": {
        "earliest_publication_year": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Earliest Publication Year"
        },
        "input_record_count": {
          "minimum": 0,
          "title": "Input Record Count",
          "type": "integer"
        },
        "latest_publication_year": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Latest Publication Year"
        },
        "pending_record_count": {
          "minimum": 0,
          "title": "Pending Record Count",
          "type": "integer"
        },
        "records_with_abstract": {
          "minimum": 0,
          "title": "Records With Abstract",
          "type": "integer"
        },
        "records_with_doi": {
          "minimum": 0,
          "title": "Records With Doi",
          "type": "integer"
        },
        "records_with_pmid": {
          "minimum": 0,
          "title": "Records With Pmid",
          "type": "integer"
        },
        "records_without_abstract": {
          "minimum": 0,
          "title": "Records Without Abstract",
          "type": "integer"
        }
      },
      "required": [
        "input_record_count",
        "pending_record_count",
        "records_with_abstract",
        "records_without_abstract",
        "records_with_doi",
        "records_with_pmid"
      ],
      "title": "ScreeningQueueSummary",
      "type": "object"
    },
    "ScreeningStatus": {
      "enum": [
        "not_started",
        "in_progress",
        "complete"
      ],
      "title": "ScreeningStatus",
      "type": "string"
    }
  },
  "additionalProperties": false,
  "properties": {
    "algorithm_version": {
      "minLength": 1,
      "title": "Algorithm Version",
      "type": "string"
    },
    "artifact_checksums_verified": {
      "title": "Artifact Checksums Verified",
      "type": "boolean"
    },
    "code_revision": {
      "pattern": "^[a-f0-9]{7,40}$",
      "title": "Code Revision",
      "type": "string"
    },
    "created_at": {
      "format": "date-time",
      "title": "Created At",
      "type": "string"
    },
    "manifest_checksum_verified": {
      "title": "Manifest Checksum Verified",
      "type": "boolean"
    },
    "manifest_object_key": {
      "minLength": 1,
      "title": "Manifest Object Key",
      "type": "string"
    },
    "manifest_sha256": {
      "pattern": "^[a-f0-9]{64}$",
      "title": "Manifest Sha256",
      "type": "string"
    },
    "queue_id": {
      "pattern": "^[a-f0-9]{64}$",
      "title": "Queue Id",
      "type": "string"
    },
    "queue_object_key": {
      "minLength": 1,
      "title": "Queue Object Key",
      "type": "string"
    },
    "queue_sha256": {
      "pattern": "^[a-f0-9]{64}$",
      "title": "Queue Sha256",
      "type": "string"
    },
    "queue_size_bytes": {
      "minimum": 0,
      "title": "Queue Size Bytes",
      "type": "integer"
    },
    "record_count_verified": {
      "title": "Record Count Verified",
      "type": "boolean"
    },
    "schema_version": {
      "default": "1.0.0",
      "title": "Schema Version",
      "type": "string"
    },
    "scientific_conclusions_drawn": {
      "title": "Scientific Conclusions Drawn",
      "type": "boolean"
    },
    "screening_status": {
      "$ref": "#/$defs/ScreeningStatus"
    },
    "search_execution_id": {
      "pattern": "^[a-f0-9]{64}$",
      "title": "Search Execution Id",
      "type": "string"
    },
    "study_id": {
      "minLength": 1,
      "title": "Study Id",
      "type": "string"
    },
    "summary": {
      "$ref": "#/$defs/ScreeningQueueSummary"
    },
    "verified_at": {
      "format": "date-time",
      "title": "Verified At",
      "type": "string"
    }
  },
  "required": [
    "queue_id",
    "study_id",
    "search_execution_id",
    "algorithm_version",
    "code_revision",
    "created_at",
    "manifest_object_key",
    "manifest_sha256",
    "queue_object_key",
    "queue_sha256",
    "queue_size_bytes",
    "summary",
    "verified_at",
    "manifest_checksum_verified",
    "artifact_checksums_verified",
    "record_count_verified",
    "screening_status",
    "scientific_conclusions_drawn"
  ],
  "title": "ScreeningQueueReceipt",
  "type": "object"
}
