{
  "$defs": {
    "ScreeningStatus": {
      "enum": [
        "not_started",
        "in_progress",
        "complete"
      ],
      "title": "ScreeningStatus",
      "type": "string"
    },
    "SourceSearchReceipt": {
      "additionalProperties": false,
      "properties": {
        "raw_object_count": {
          "minimum": 1,
          "title": "Raw Object Count",
          "type": "integer"
        },
        "reported_result_count": {
          "minimum": 0,
          "title": "Reported Result Count",
          "type": "integer"
        },
        "request_count": {
          "minimum": 1,
          "title": "Request Count",
          "type": "integer"
        },
        "retrieved_record_count": {
          "minimum": 0,
          "title": "Retrieved Record Count",
          "type": "integer"
        },
        "source_id": {
          "minLength": 1,
          "title": "Source Id",
          "type": "string"
        }
      },
      "required": [
        "source_id",
        "reported_result_count",
        "retrieved_record_count",
        "request_count",
        "raw_object_count"
      ],
      "title": "SourceSearchReceipt",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "properties": {
    "duplicate_record_count": {
      "minimum": 0,
      "title": "Duplicate Record Count",
      "type": "integer"
    },
    "executed_at": {
      "format": "date-time",
      "title": "Executed At",
      "type": "string"
    },
    "execution_id": {
      "pattern": "^[a-f0-9]{64}$",
      "title": "Execution Id",
      "type": "string"
    },
    "manifest_checksum_verified": {
      "title": "Manifest Checksum Verified",
      "type": "boolean"
    },
    "manifest_object_key": {
      "minLength": 1,
      "title": "Manifest Object Key",
      "type": "string"
    },
    "manifest_sha256": {
      "pattern": "^[a-f0-9]{64}$",
      "title": "Manifest Sha256",
      "type": "string"
    },
    "normalized_records_object_key": {
      "minLength": 1,
      "title": "Normalized Records Object Key",
      "type": "string"
    },
    "normalized_records_sha256": {
      "pattern": "^[a-f0-9]{64}$",
      "title": "Normalized Records Sha256",
      "type": "string"
    },
    "normalized_records_size_bytes": {
      "minimum": 0,
      "title": "Normalized Records Size Bytes",
      "type": "integer"
    },
    "object_checksums_verified": {
      "title": "Object Checksums Verified",
      "type": "boolean"
    },
    "object_sizes_verified": {
      "title": "Object Sizes Verified",
      "type": "boolean"
    },
    "outcome_data_accessed": {
      "title": "Outcome Data Accessed",
      "type": "boolean"
    },
    "question_id": {
      "minLength": 1,
      "title": "Question Id",
      "type": "string"
    },
    "question_version": {
      "minLength": 1,
      "title": "Question Version",
      "type": "string"
    },
    "record_count_invariants_verified": {
      "title": "Record Count Invariants Verified",
      "type": "boolean"
    },
    "schema_version": {
      "default": "1.0.0",
      "title": "Schema Version",
      "type": "string"
    },
    "scientific_conclusions_drawn": {
      "title": "Scientific Conclusions Drawn",
      "type": "boolean"
    },
    "screening_status": {
      "$ref": "#/$defs/ScreeningStatus"
    },
    "source_results": {
      "items": {
        "$ref": "#/$defs/SourceSearchReceipt"
      },
      "minItems": 2,
      "title": "Source Results",
      "type": "array"
    },
    "strategy_version": {
      "minLength": 1,
      "title": "Strategy Version",
      "type": "string"
    },
    "study_id": {
      "minLength": 1,
      "title": "Study Id",
      "type": "string"
    },
    "unique_record_count": {
      "minimum": 0,
      "title": "Unique Record Count",
      "type": "integer"
    },
    "verified_at": {
      "format": "date-time",
      "title": "Verified At",
      "type": "string"
    },
    "verified_object_count": {
      "minimum": 1,
      "title": "Verified Object Count",
      "type": "integer"
    }
  },
  "required": [
    "execution_id",
    "study_id",
    "question_id",
    "question_version",
    "strategy_version",
    "executed_at",
    "source_results",
    "unique_record_count",
    "duplicate_record_count",
    "manifest_object_key",
    "manifest_sha256",
    "normalized_records_object_key",
    "normalized_records_sha256",
    "normalized_records_size_bytes",
    "verified_at",
    "manifest_checksum_verified",
    "object_checksums_verified",
    "object_sizes_verified",
    "record_count_invariants_verified",
    "verified_object_count",
    "screening_status",
    "scientific_conclusions_drawn",
    "outcome_data_accessed"
  ],
  "title": "LiteratureSearchReceipt",
  "type": "object"
}
