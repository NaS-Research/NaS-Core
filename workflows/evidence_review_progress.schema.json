{
  "$defs": {
    "CitationChainPass": {
      "additionalProperties": false,
      "properties": {
        "backward_candidate_count": {
          "minimum": 0,
          "title": "Backward Candidate Count",
          "type": "integer"
        },
        "backward_source": {
          "pattern": "^europe_pmc_references$",
          "title": "Backward Source",
          "type": "string"
        },
        "completed_at": {
          "anyOf": [
            {
              "format": "date-time",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Completed At"
        },
        "forward_candidate_count": {
          "minimum": 0,
          "title": "Forward Candidate Count",
          "type": "integer"
        },
        "forward_source": {
          "pattern": "^europe_pmc_citations$",
          "title": "Forward Source",
          "type": "string"
        },
        "new_eligible_evidence_ids": {
          "items": {
            "type": "string"
          },
          "title": "New Eligible Evidence Ids",
          "type": "array"
        },
        "pass_number": {
          "minimum": 1,
          "title": "Pass Number",
          "type": "integer"
        },
        "screened_candidate_count": {
          "minimum": 0,
          "title": "Screened Candidate Count",
          "type": "integer"
        },
        "seed_evidence_ids": {
          "items": {
            "type": "string"
          },
          "minItems": 1,
          "title": "Seed Evidence Ids",
          "type": "array"
        },
        "status": {
          "$ref": "#/$defs/CitationPassStatus"
        },
        "unique_candidate_count": {
          "minimum": 0,
          "title": "Unique Candidate Count",
          "type": "integer"
        }
      },
      "required": [
        "pass_number",
        "status",
        "seed_evidence_ids",
        "backward_source",
        "forward_source",
        "backward_candidate_count",
        "forward_candidate_count",
        "unique_candidate_count",
        "screened_candidate_count",
        "new_eligible_evidence_ids"
      ],
      "title": "CitationChainPass",
      "type": "object"
    },
    "CitationPassStatus": {
      "enum": [
        "planned",
        "complete"
      ],
      "title": "CitationPassStatus",
      "type": "string"
    },
    "ReviewStatus": {
      "enum": [
        "draft",
        "active",
        "complete"
      ],
      "title": "ReviewStatus",
      "type": "string"
    }
  },
  "additionalProperties": false,
  "properties": {
    "access_restricted_count": {
      "maximum": 30,
      "minimum": 0,
      "title": "Access Restricted Count",
      "type": "integer"
    },
    "citation_passes": {
      "items": {
        "$ref": "#/$defs/CitationChainPass"
      },
      "title": "Citation Passes",
      "type": "array"
    },
    "completed_appraisal_count": {
      "maximum": 30,
      "minimum": 0,
      "title": "Completed Appraisal Count",
      "type": "integer"
    },
    "deduplication_complete": {
      "title": "Deduplication Complete",
      "type": "boolean"
    },
    "eligible_evidence_count": {
      "maximum": 30,
      "minimum": 0,
      "title": "Eligible Evidence Count",
      "type": "integer"
    },
    "locked_search_executed": {
      "title": "Locked Search Executed",
      "type": "boolean"
    },
    "molecular_data_access_authorized": {
      "title": "Molecular Data Access Authorized",
      "type": "boolean"
    },
    "novelty_claim_authorized": {
      "title": "Novelty Claim Authorized",
      "type": "boolean"
    },
    "outcome_data_access_authorized": {
      "title": "Outcome Data Access Authorized",
      "type": "boolean"
    },
    "pending_candidate_count": {
      "minimum": 0,
      "title": "Pending Candidate Count",
      "type": "integer"
    },
    "primary_screening_complete": {
      "title": "Primary Screening Complete",
      "type": "boolean"
    },
    "priority_set_version": {
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$",
      "title": "Priority Set Version",
      "type": "string"
    },
    "progress_version": {
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$",
      "title": "Progress Version",
      "type": "string"
    },
    "question_id": {
      "pattern": "^NAS-RQ-[A-Z0-9]+$",
      "title": "Question Id",
      "type": "string"
    },
    "question_version": {
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$",
      "title": "Question Version",
      "type": "string"
    },
    "review_status": {
      "$ref": "#/$defs/ReviewStatus"
    },
    "schema_version": {
      "default": "1.0.0",
      "title": "Schema Version",
      "type": "string"
    },
    "search_strategy_version": {
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$",
      "title": "Search Strategy Version",
      "type": "string"
    },
    "stopping_rule_satisfied": {
      "title": "Stopping Rule Satisfied",
      "type": "boolean"
    },
    "study_id": {
      "pattern": "^NAS-[A-Z0-9]+-[0-9]{3}$",
      "title": "Study Id",
      "type": "string"
    },
    "unresolved_claims": {
      "items": {
        "type": "string"
      },
      "minItems": 1,
      "title": "Unresolved Claims",
      "type": "array"
    }
  },
  "required": [
    "progress_version",
    "study_id",
    "question_id",
    "question_version",
    "review_status",
    "search_strategy_version",
    "priority_set_version",
    "locked_search_executed",
    "deduplication_complete",
    "primary_screening_complete",
    "eligible_evidence_count",
    "completed_appraisal_count",
    "access_restricted_count",
    "pending_candidate_count",
    "citation_passes",
    "unresolved_claims",
    "stopping_rule_satisfied",
    "novelty_claim_authorized",
    "molecular_data_access_authorized",
    "outcome_data_access_authorized"
  ],
  "title": "EvidenceReviewProgress",
  "type": "object"
}
