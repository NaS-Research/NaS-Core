{
  "$defs": {
    "CohortArtifact": {
      "additionalProperties": false,
      "properties": {
        "media_type": {
          "minLength": 1,
          "title": "Media Type",
          "type": "string"
        },
        "object_key": {
          "minLength": 1,
          "title": "Object Key",
          "type": "string"
        },
        "sha256": {
          "pattern": "^[a-f0-9]{64}$",
          "title": "Sha256",
          "type": "string"
        },
        "size_bytes": {
          "minimum": 0,
          "title": "Size Bytes",
          "type": "integer"
        }
      },
      "required": [
        "object_key",
        "media_type",
        "size_bytes",
        "sha256"
      ],
      "title": "CohortArtifact",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "properties": {
    "algorithm_version": {
      "minLength": 1,
      "title": "Algorithm Version",
      "type": "string"
    },
    "artifacts": {
      "items": {
        "$ref": "#/$defs/CohortArtifact"
      },
      "minItems": 3,
      "title": "Artifacts",
      "type": "array"
    },
    "build_id": {
      "pattern": "^[a-f0-9]{64}$",
      "title": "Build Id",
      "type": "string"
    },
    "built_at": {
      "format": "date-time",
      "title": "Built At",
      "type": "string"
    },
    "code_revision": {
      "minLength": 7,
      "title": "Code Revision",
      "type": "string"
    },
    "excluded_case_count": {
      "minimum": 0,
      "title": "Excluded Case Count",
      "type": "integer"
    },
    "included_case_count": {
      "minimum": 0,
      "title": "Included Case Count",
      "type": "integer"
    },
    "input_case_count": {
      "minimum": 0,
      "title": "Input Case Count",
      "type": "integer"
    },
    "manifest_sha256": {
      "anyOf": [
        {
          "pattern": "^[a-f0-9]{64}$",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Manifest Sha256"
    },
    "outcome_analysis_performed": {
      "const": false,
      "default": false,
      "title": "Outcome Analysis Performed",
      "type": "boolean"
    },
    "protocol_tag": {
      "minLength": 1,
      "title": "Protocol Tag",
      "type": "string"
    },
    "protocol_version": {
      "minLength": 1,
      "title": "Protocol Version",
      "type": "string"
    },
    "schema_version": {
      "default": "1.0.0",
      "title": "Schema Version",
      "type": "string"
    },
    "snapshot_id": {
      "pattern": "^[a-f0-9]{64}$",
      "title": "Snapshot Id",
      "type": "string"
    },
    "snapshot_manifest_sha256": {
      "pattern": "^[a-f0-9]{64}$",
      "title": "Snapshot Manifest Sha256",
      "type": "string"
    },
    "study_id": {
      "minLength": 1,
      "title": "Study Id",
      "type": "string"
    }
  },
  "required": [
    "build_id",
    "study_id",
    "protocol_version",
    "protocol_tag",
    "snapshot_id",
    "snapshot_manifest_sha256",
    "algorithm_version",
    "code_revision",
    "built_at",
    "input_case_count",
    "included_case_count",
    "excluded_case_count",
    "artifacts"
  ],
  "title": "CohortBuildManifest",
  "type": "object"
}
