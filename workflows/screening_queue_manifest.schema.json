{
  "$defs": {
    "ScreeningQueueSummary": {
      "additionalProperties": false,
      "properties": {
        "earliest_publication_year": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Earliest Publication Year"
        },
        "input_record_count": {
          "minimum": 0,
          "title": "Input Record Count",
          "type": "integer"
        },
        "latest_publication_year": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Latest Publication Year"
        },
        "pending_record_count": {
          "minimum": 0,
          "title": "Pending Record Count",
          "type": "integer"
        },
        "records_with_abstract": {
          "minimum": 0,
          "title": "Records With Abstract",
          "type": "integer"
        },
        "records_with_doi": {
          "minimum": 0,
          "title": "Records With Doi",
          "type": "integer"
        },
        "records_with_pmid": {
          "minimum": 0,
          "title": "Records With Pmid",
          "type": "integer"
        },
        "records_without_abstract": {
          "minimum": 0,
          "title": "Records Without Abstract",
          "type": "integer"
        }
      },
      "required": [
        "input_record_count",
        "pending_record_count",
        "records_with_abstract",
        "records_without_abstract",
        "records_with_doi",
        "records_with_pmid"
      ],
      "title": "ScreeningQueueSummary",
      "type": "object"
    },
    "StoredObject": {
      "additionalProperties": false,
      "properties": {
        "file_ids": {
          "items": {
            "type": "string"
          },
          "title": "File Ids",
          "type": "array"
        },
        "media_type": {
          "minLength": 1,
          "title": "Media Type",
          "type": "string"
        },
        "object_key": {
          "minLength": 1,
          "title": "Object Key",
          "type": "string"
        },
        "record_ids": {
          "items": {
            "type": "string"
          },
          "title": "Record Ids",
          "type": "array"
        },
        "sha256": {
          "pattern": "^[a-f0-9]{64}$",
          "title": "Sha256",
          "type": "string"
        },
        "size_bytes": {
          "minimum": 0,
          "title": "Size Bytes",
          "type": "integer"
        }
      },
      "required": [
        "object_key",
        "media_type",
        "size_bytes",
        "sha256"
      ],
      "title": "StoredObject",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "properties": {
    "ai_decisions_recorded": {
      "minimum": 0,
      "title": "Ai Decisions Recorded",
      "type": "integer"
    },
    "algorithm_version": {
      "minLength": 1,
      "title": "Algorithm Version",
      "type": "string"
    },
    "artifacts": {
      "items": {
        "$ref": "#/$defs/StoredObject"
      },
      "minItems": 2,
      "title": "Artifacts",
      "type": "array"
    },
    "code_revision": {
      "pattern": "^[a-f0-9]{7,40}$",
      "title": "Code Revision",
      "type": "string"
    },
    "created_at": {
      "format": "date-time",
      "title": "Created At",
      "type": "string"
    },
    "human_decisions_recorded": {
      "minimum": 0,
      "title": "Human Decisions Recorded",
      "type": "integer"
    },
    "input_object_key": {
      "minLength": 1,
      "title": "Input Object Key",
      "type": "string"
    },
    "input_sha256": {
      "pattern": "^[a-f0-9]{64}$",
      "title": "Input Sha256",
      "type": "string"
    },
    "manifest_sha256": {
      "anyOf": [
        {
          "pattern": "^[a-f0-9]{64}$",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Manifest Sha256"
    },
    "question_id": {
      "minLength": 1,
      "title": "Question Id",
      "type": "string"
    },
    "question_version": {
      "minLength": 1,
      "title": "Question Version",
      "type": "string"
    },
    "queue_id": {
      "pattern": "^[a-f0-9]{64}$",
      "title": "Queue Id",
      "type": "string"
    },
    "schema_version": {
      "default": "1.0.0",
      "title": "Schema Version",
      "type": "string"
    },
    "search_execution_id": {
      "pattern": "^[a-f0-9]{64}$",
      "title": "Search Execution Id",
      "type": "string"
    },
    "strategy_version": {
      "minLength": 1,
      "title": "Strategy Version",
      "type": "string"
    },
    "study_id": {
      "minLength": 1,
      "title": "Study Id",
      "type": "string"
    },
    "summary": {
      "$ref": "#/$defs/ScreeningQueueSummary"
    }
  },
  "required": [
    "queue_id",
    "study_id",
    "question_id",
    "question_version",
    "strategy_version",
    "search_execution_id",
    "algorithm_version",
    "code_revision",
    "created_at",
    "input_object_key",
    "input_sha256",
    "artifacts",
    "summary",
    "human_decisions_recorded",
    "ai_decisions_recorded"
  ],
  "title": "ScreeningQueueManifest",
  "type": "object"
}
