{
  "$defs": {
    "AIAdvisorySummary": {
      "additionalProperties": false,
      "properties": {
        "exclude_count": {
          "minimum": 0,
          "title": "Exclude Count",
          "type": "integer"
        },
        "high_confidence_count": {
          "minimum": 0,
          "title": "High Confidence Count",
          "type": "integer"
        },
        "human_decisions_recorded": {
          "minimum": 0,
          "title": "Human Decisions Recorded",
          "type": "integer"
        },
        "include_count": {
          "minimum": 0,
          "title": "Include Count",
          "type": "integer"
        },
        "low_confidence_count": {
          "minimum": 0,
          "title": "Low Confidence Count",
          "type": "integer"
        },
        "moderate_confidence_count": {
          "minimum": 0,
          "title": "Moderate Confidence Count",
          "type": "integer"
        },
        "recommendation_count": {
          "minimum": 1,
          "title": "Recommendation Count",
          "type": "integer"
        },
        "requested_record_count": {
          "minimum": 1,
          "title": "Requested Record Count",
          "type": "integer"
        },
        "unclear_count": {
          "minimum": 0,
          "title": "Unclear Count",
          "type": "integer"
        }
      },
      "required": [
        "requested_record_count",
        "recommendation_count",
        "include_count",
        "exclude_count",
        "unclear_count",
        "high_confidence_count",
        "moderate_confidence_count",
        "low_confidence_count",
        "human_decisions_recorded"
      ],
      "title": "AIAdvisorySummary",
      "type": "object"
    },
    "AIModelCall": {
      "additionalProperties": false,
      "properties": {
        "input_tokens": {
          "minimum": 0,
          "title": "Input Tokens",
          "type": "integer"
        },
        "model": {
          "minLength": 1,
          "title": "Model",
          "type": "string"
        },
        "output_tokens": {
          "minimum": 0,
          "title": "Output Tokens",
          "type": "integer"
        },
        "provider": {
          "minLength": 1,
          "title": "Provider",
          "type": "string"
        },
        "response_id": {
          "minLength": 1,
          "title": "Response Id",
          "type": "string"
        }
      },
      "required": [
        "provider",
        "model",
        "response_id",
        "input_tokens",
        "output_tokens"
      ],
      "title": "AIModelCall",
      "type": "object"
    },
    "StoredObject": {
      "additionalProperties": false,
      "properties": {
        "file_ids": {
          "items": {
            "type": "string"
          },
          "title": "File Ids",
          "type": "array"
        },
        "media_type": {
          "minLength": 1,
          "title": "Media Type",
          "type": "string"
        },
        "object_key": {
          "minLength": 1,
          "title": "Object Key",
          "type": "string"
        },
        "record_ids": {
          "items": {
            "type": "string"
          },
          "title": "Record Ids",
          "type": "array"
        },
        "sha256": {
          "pattern": "^[a-f0-9]{64}$",
          "title": "Sha256",
          "type": "string"
        },
        "size_bytes": {
          "minimum": 0,
          "title": "Size Bytes",
          "type": "integer"
        }
      },
      "required": [
        "object_key",
        "media_type",
        "size_bytes",
        "sha256"
      ],
      "title": "StoredObject",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "properties": {
    "advisory_run_id": {
      "pattern": "^[a-f0-9]{64}$",
      "title": "Advisory Run Id",
      "type": "string"
    },
    "artifacts": {
      "items": {
        "$ref": "#/$defs/StoredObject"
      },
      "maxItems": 3,
      "minItems": 3,
      "title": "Artifacts",
      "type": "array"
    },
    "autonomous_decisions_allowed": {
      "title": "Autonomous Decisions Allowed",
      "type": "boolean"
    },
    "based_on_progress_id": {
      "anyOf": [
        {
          "pattern": "^[a-f0-9]{64}$",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Based On Progress Id"
    },
    "code_revision": {
      "pattern": "^[a-f0-9]{7,40}$",
      "title": "Code Revision",
      "type": "string"
    },
    "created_at": {
      "format": "date-time",
      "title": "Created At",
      "type": "string"
    },
    "final_decisions_recorded": {
      "minimum": 0,
      "title": "Final Decisions Recorded",
      "type": "integer"
    },
    "input_sha256": {
      "pattern": "^[a-f0-9]{64}$",
      "title": "Input Sha256",
      "type": "string"
    },
    "manifest_sha256": {
      "anyOf": [
        {
          "pattern": "^[a-f0-9]{64}$",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Manifest Sha256"
    },
    "model_call": {
      "$ref": "#/$defs/AIModelCall"
    },
    "policy_sha256": {
      "pattern": "^[a-f0-9]{64}$",
      "title": "Policy Sha256",
      "type": "string"
    },
    "policy_version": {
      "minLength": 1,
      "title": "Policy Version",
      "type": "string"
    },
    "prompt_sha256": {
      "pattern": "^[a-f0-9]{64}$",
      "title": "Prompt Sha256",
      "type": "string"
    },
    "queue_id": {
      "pattern": "^[a-f0-9]{64}$",
      "title": "Queue Id",
      "type": "string"
    },
    "schema_version": {
      "default": "1.0.0",
      "title": "Schema Version",
      "type": "string"
    },
    "scientific_conclusions_drawn": {
      "title": "Scientific Conclusions Drawn",
      "type": "boolean"
    },
    "summary": {
      "$ref": "#/$defs/AIAdvisorySummary"
    }
  },
  "required": [
    "advisory_run_id",
    "queue_id",
    "policy_version",
    "policy_sha256",
    "prompt_sha256",
    "input_sha256",
    "code_revision",
    "created_at",
    "model_call",
    "artifacts",
    "summary",
    "autonomous_decisions_allowed",
    "final_decisions_recorded",
    "scientific_conclusions_drawn"
  ],
  "title": "AIAdvisoryManifest",
  "type": "object"
}
