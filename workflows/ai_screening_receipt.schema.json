{
  "$defs": {
    "AIAdvisorySummary": {
      "additionalProperties": false,
      "properties": {
        "exclude_count": {
          "minimum": 0,
          "title": "Exclude Count",
          "type": "integer"
        },
        "high_confidence_count": {
          "minimum": 0,
          "title": "High Confidence Count",
          "type": "integer"
        },
        "human_decisions_recorded": {
          "minimum": 0,
          "title": "Human Decisions Recorded",
          "type": "integer"
        },
        "include_count": {
          "minimum": 0,
          "title": "Include Count",
          "type": "integer"
        },
        "low_confidence_count": {
          "minimum": 0,
          "title": "Low Confidence Count",
          "type": "integer"
        },
        "moderate_confidence_count": {
          "minimum": 0,
          "title": "Moderate Confidence Count",
          "type": "integer"
        },
        "recommendation_count": {
          "minimum": 1,
          "title": "Recommendation Count",
          "type": "integer"
        },
        "requested_record_count": {
          "minimum": 1,
          "title": "Requested Record Count",
          "type": "integer"
        },
        "unclear_count": {
          "minimum": 0,
          "title": "Unclear Count",
          "type": "integer"
        }
      },
      "required": [
        "requested_record_count",
        "recommendation_count",
        "include_count",
        "exclude_count",
        "unclear_count",
        "high_confidence_count",
        "moderate_confidence_count",
        "low_confidence_count",
        "human_decisions_recorded"
      ],
      "title": "AIAdvisorySummary",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "properties": {
    "advisory_run_id": {
      "pattern": "^[a-f0-9]{64}$",
      "title": "Advisory Run Id",
      "type": "string"
    },
    "artifact_checksums_verified": {
      "title": "Artifact Checksums Verified",
      "type": "boolean"
    },
    "autonomous_decisions_allowed": {
      "title": "Autonomous Decisions Allowed",
      "type": "boolean"
    },
    "based_on_progress_id": {
      "anyOf": [
        {
          "pattern": "^[a-f0-9]{64}$",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Based On Progress Id"
    },
    "calibration_status": {
      "pattern": "^required$",
      "title": "Calibration Status",
      "type": "string"
    },
    "code_revision": {
      "pattern": "^[a-f0-9]{7,40}$",
      "title": "Code Revision",
      "type": "string"
    },
    "count_invariants_verified": {
      "title": "Count Invariants Verified",
      "type": "boolean"
    },
    "created_at": {
      "format": "date-time",
      "title": "Created At",
      "type": "string"
    },
    "evidence_references_verified": {
      "title": "Evidence References Verified",
      "type": "boolean"
    },
    "final_decisions_recorded": {
      "minimum": 0,
      "title": "Final Decisions Recorded",
      "type": "integer"
    },
    "manifest_checksum_verified": {
      "title": "Manifest Checksum Verified",
      "type": "boolean"
    },
    "manifest_object_key": {
      "minLength": 1,
      "title": "Manifest Object Key",
      "type": "string"
    },
    "manifest_sha256": {
      "pattern": "^[a-f0-9]{64}$",
      "title": "Manifest Sha256",
      "type": "string"
    },
    "model": {
      "minLength": 1,
      "title": "Model",
      "type": "string"
    },
    "policy_version": {
      "minLength": 1,
      "title": "Policy Version",
      "type": "string"
    },
    "provider": {
      "minLength": 1,
      "title": "Provider",
      "type": "string"
    },
    "queue_id": {
      "pattern": "^[a-f0-9]{64}$",
      "title": "Queue Id",
      "type": "string"
    },
    "schema_version": {
      "default": "1.0.0",
      "title": "Schema Version",
      "type": "string"
    },
    "scientific_conclusions_drawn": {
      "title": "Scientific Conclusions Drawn",
      "type": "boolean"
    },
    "summary": {
      "$ref": "#/$defs/AIAdvisorySummary"
    },
    "verified_at": {
      "format": "date-time",
      "title": "Verified At",
      "type": "string"
    }
  },
  "required": [
    "advisory_run_id",
    "queue_id",
    "policy_version",
    "provider",
    "model",
    "code_revision",
    "created_at",
    "manifest_object_key",
    "manifest_sha256",
    "summary",
    "verified_at",
    "manifest_checksum_verified",
    "artifact_checksums_verified",
    "evidence_references_verified",
    "count_invariants_verified",
    "calibration_status",
    "autonomous_decisions_allowed",
    "final_decisions_recorded",
    "scientific_conclusions_drawn"
  ],
  "title": "AIAdvisoryReceipt",
  "type": "object"
}
